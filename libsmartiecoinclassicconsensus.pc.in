prefix=@prefix@
exec_prefix=@exec_prefix@
libdir=@libdir@
includedir=@includedir@

Name: Smartiecoin Classic consensus library
Description: Library for the Smartiecoin Classic consensus protocol.
Version: @PACKAGE_VERSION@
Libs: -L${libdir} -lsmartiecoinclassicconsensus
Cflags: -I${includedir}
Requires.private: libcrypto
